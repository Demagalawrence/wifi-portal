# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default is SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# Payment Settings
API_PUBLIC_BASE_URL=http://localhost:8000
PAYMENT_SIMULATION_ENABLED=True

AIRTEL_MONEY_API_URL=https://api.airtel.com/v1
AIRTEL_MONEY_CLIENT_ID=your-airtel-client-id
AIRTEL_MONEY_CLIENT_SECRET=your-airtel-client-secret

MTN_MONEY_API_URL=https://api.mtn.com/v1
MTN_MONEY_CLIENT_ID=your-mtn-client-id
MTN_MONEY_CLIENT_SECRET=your-mtn-client-secret

# WiFi Settings
WIFI_SESSION_TIMEOUT=3600
WIFI_MAX_CONCURRENT_USERS=100
